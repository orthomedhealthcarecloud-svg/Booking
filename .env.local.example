# Copy this file to .env.local and fill in real values.
# See SETUP.md for where to get each value.

# ---------- Firebase Web SDK (client-side) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- Firebase Admin (server-side) ----------
# Either point at a JSON file...
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-admin.json
# ...or paste the service-account JSON inline (Vercel-friendly).
# FIREBASE_SERVICE_ACCOUNT_JSON=

# ---------- reCAPTCHA v3 ----------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---------- Razorpay ----------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# ---------- Google OAuth (Calendar API) ----------
# Used to create a calendar event + Meet link per booking on the doctor's calendar.
# Get these from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Override only if you need a non-standard redirect — otherwise the app uses NEXT_PUBLIC_APP_URL.
GOOGLE_OAUTH_REDIRECT_URI=
# Public base URL (used to build the OAuth redirect). Set per-environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- WhatsApp (optional) ----------
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_SENDER_NUMBER=

# ---------- Doctor 1 — /manoj ----------
DOCTOR_MANOJ_NAME="Dr. Manoj Iyer"
DOCTOR_MANOJ_QUALIFICATIONS="MS Ortho, DNB · Orthopaedic Surgeon"
DOCTOR_MANOJ_SPECIALTY="Orthopaedic Surgeon"
DOCTOR_MANOJ_REGISTRATION=""
DOCTOR_MANOJ_EXPERIENCE_YEARS=18
DOCTOR_MANOJ_LANGUAGES="English, Hindi, Marathi"
DOCTOR_MANOJ_TIMEZONE="Asia/Kolkata"
DOCTOR_MANOJ_VIDEO_FEE=800
DOCTOR_MANOJ_TEXT_FEE=500
DOCTOR_MANOJ_GOOGLE_MEET_URL=""
DOCTOR_MANOJ_ADMIN_EMAIL=""
DOCTOR_MANOJ_CLINIC_NAME=""
DOCTOR_MANOJ_CLINIC_ADDRESS=""
DOCTOR_MANOJ_CLINIC_PHONE=""

# ---------- Doctor 2 — /manoj2 ----------
DOCTOR_MANOJ2_NAME="Dr. Manoj"
DOCTOR_MANOJ2_QUALIFICATIONS=""
DOCTOR_MANOJ2_SPECIALTY=""
DOCTOR_MANOJ2_REGISTRATION=""
DOCTOR_MANOJ2_EXPERIENCE_YEARS=0
DOCTOR_MANOJ2_LANGUAGES=""
DOCTOR_MANOJ2_TIMEZONE="Asia/Kolkata"
DOCTOR_MANOJ2_VIDEO_FEE=800
DOCTOR_MANOJ2_TEXT_FEE=500
DOCTOR_MANOJ2_GOOGLE_MEET_URL=""
DOCTOR_MANOJ2_ADMIN_EMAIL=""
DOCTOR_MANOJ2_CLINIC_NAME=""
DOCTOR_MANOJ2_CLINIC_ADDRESS=""
DOCTOR_MANOJ2_CLINIC_PHONE=""
